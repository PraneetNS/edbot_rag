# Edmentor Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Ollama (Local LLM — optional) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── JWT Authentication (Security) ──────────────────────────────────────────
# Secret key used for signing JWT tokens (should be a long random string in production)
SECRET_KEY=your-jwt-secret-key-change-this-in-production
# Token expiration duration in hours
JWT_EXPIRE_HOURS=24

